# Copy to .env and adjust. .env is gitignored and must never contain committed real credentials.

# SQLite (default): path to the database file. No credentials needed.
BUS_DB_PATH=data/processed/bus_analytics.db

# If porting the schema to PostgreSQL, supply connection details via env (never hard-code them):
# BUS_DB_URL=postgresql://USER:PASSWORD@HOST:5432/bus_analytics
